---
import { type Lang, t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const youtubeUrl = 'https://www.youtube.com/watch?v=0Wb-eaG1Vio&t=71s';
const base = import.meta.env.BASE_URL;
---

<section id="reel" class="wrap section-reveal reel-section">
  <div class="reveal reel-header">
    <div>
      <span class="kick">{t(lang, 'reel.label')}</span>
      <h2 class="disp reel-title">{t(lang, 'reel.title')}</h2>
    </div>
    <a href={youtubeUrl} target="_blank" rel="noopener" class="youtube-link">
      {t(lang, 'reel.youtube')}
    </a>
  </div>
  <a href={youtubeUrl} target="_blank" rel="noopener" class="reel-link reveal-scale delay-2">
    <div class="reel-thumbnail">
      <img
        src={`${base}images/Screenshot 2026-07-19 at 12.25.53.png`}
        alt="Showreel - UGEGRAAF Documentary"
        loading="lazy"
        decoding="async"
      />
      <div class="reel-overlay">
        <span class="play-btn">
          <svg class="play-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </span>
      </div>
    </div>
  </a>
</section>

<style>
  .reel-section {
    padding-top: clamp(56px, 7vw, 96px);
    padding-bottom: clamp(40px, 5vw, 64px);
  }

  .reel-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 26px;
    gap: 16px;
    flex-wrap: wrap;
  }

  .reel-title {
    font-size: clamp(34px, 4vw, 48px);
    margin: 12px 0 0;
  }

  .youtube-link {
    font-family: var(--font-body);
    font-size: 14px;
  }

  .reel-link {
    display: block;
    text-decoration: none;
  }

  .reel-thumbnail {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    border-radius: 4px;
    background: #0a0806;
  }

  .reel-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reel-link:hover .reel-thumbnail img {
    transform: scale(1.03);
  }

  .reel-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }

  .reel-link:hover .reel-overlay {
    background: rgba(0, 0, 0, 0.4);
  }

  .play-btn {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    color: #1a1816;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
  }

  .reel-link:hover .play-btn {
    transform: scale(1.08);
  }

  .play-icon {
    width: 28px;
    height: 28px;
    margin-left: 3px;
  }

  @media (max-width: 900px) {
    .reel-section {
      padding-top: 48px;
      padding-bottom: 32px;
    }

    .reel-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }

  @media (max-width: 600px) {
    .reel-section {
      padding-top: 40px;
      padding-bottom: 24px;
    }

    .reel-title {
      font-size: clamp(26px, 7vw, 34px);
    }

    .play-btn {
      width: 56px;
      height: 56px;
    }

    .play-icon {
      width: 22px;
      height: 22px;
    }
  }
</style>
