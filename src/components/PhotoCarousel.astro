---
const photos = [1, 2, 3, 4, 5, 6, 7];
const base = import.meta.env.BASE_URL;
---

<section id="photos" class="section-reveal photo-section">
  <div class="photo-carousel" id="photo-carousel">
    <div class="carousel-track" id="carousel-track">
      {/* Original set */}
      {photos.map((num, index) => (
        <div class="carousel-slide" data-index={index}>
          <img
            src={`${base}images/photos/${num}.jpg`}
            alt={`Photography by P.V. - ${num}`}
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
      {/* Duplicate for seamless loop */}
      {photos.map((num, index) => (
        <div class="carousel-slide" data-index={index}>
          <img
            src={`${base}images/photos/${num}.jpg`}
            alt={`Photography by P.V. - ${num}`}
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox with navigation -->
<div class="lightbox" id="lightbox">
  <button class="lightbox-close" aria-label="Close">&times;</button>
  <button class="lightbox-nav lightbox-prev" aria-label="Previous photo">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M15 18l-6-6 6-6"/>
    </svg>
  </button>
  <img src="" alt="Full size photo" id="lightbox-img" />
  <button class="lightbox-nav lightbox-next" aria-label="Next photo">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M9 18l6-6-6-6"/>
    </svg>
  </button>
  </div>

<style>
  .photo-section {
    padding-top: clamp(40px, 5vw, 64px);
    padding-bottom: clamp(40px, 5vw, 64px);
  }

  .photo-carousel {
    cursor: grab;
    user-select: none;
  }

  .photo-carousel.is-dragging {
    cursor: grabbing;
  }

  .photo-carousel.is-dragging .carousel-track {
    animation-play-state: paused;
  }

  /* Lightbox navigation */
  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.08);
    border: none;
    color: rgba(255, 255, 255, 0.6);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease, background 0.3s ease, color 0.3s ease, transform 0.3s ease;
    z-index: 10;
  }

  :global(.lightbox:hover) .lightbox-nav {
    opacity: 1;
  }

  .lightbox-nav:hover {
    background: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.95);
    transform: translateY(-50%) scale(1.08);
  }

  .lightbox-nav:focus-visible {
    opacity: 1;
    outline: 2px solid rgba(255, 255, 255, 0.5);
    outline-offset: 2px;
  }

  .lightbox-prev {
    left: 24px;
  }

  .lightbox-next {
    right: 24px;
  }

  @media (max-width: 768px) {
    .lightbox-nav {
      width: 44px;
      height: 44px;
      opacity: 0.8;
    }
    :global(.lightbox:hover) .lightbox-nav {
      opacity: 1;
    }
    .lightbox-prev {
      left: 12px;
    }
    .lightbox-next {
      right: 12px;
    }
  }
</style>

<script>
  // Global state for lightbox navigation
  const lightboxState = {
    currentIndex: 0,
    photoCount: 7,
    base: '/',
    initialized: false
  };

  function initPhotoCarousel() {
    const photos = Array.from({ length: lightboxState.photoCount }, (_, i) => i + 1);
    lightboxState.base = document.querySelector('.carousel-slide img')?.getAttribute('src')?.replace(/images\/photos\/\d+\.jpg$/, '') || '/';

    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxClose = document.querySelector('.lightbox-close');
    const lightboxPrev = document.querySelector('.lightbox-prev');
    const lightboxNext = document.querySelector('.lightbox-next');
    const carousel = document.getElementById('photo-carousel');
    const track = document.getElementById('carousel-track');
    const carouselSlides = document.querySelectorAll('.carousel-slide');

    if (!lightbox || !carousel) return;

    function showPhoto(index: number) {
      lightboxState.currentIndex = ((index % lightboxState.photoCount) + lightboxState.photoCount) % lightboxState.photoCount;
      const photoNum = photos[lightboxState.currentIndex];
      if (lightboxImg) {
        lightboxImg.src = `${lightboxState.base}images/photos/${photoNum}.jpg`;
        lightboxImg.alt = `Photography by P.V. - ${photoNum}`;
      }
    }

    function closeLightbox() {
      lightbox?.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    // Open lightbox on click
    carouselSlides.forEach(slide => {
      slide.addEventListener('click', () => {
        if (carousel?.classList.contains('just-dragged')) return;
        const index = parseInt(slide.getAttribute('data-index') || '0');
        showPhoto(index);
        lightbox?.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      });
    });

    lightboxPrev?.addEventListener('click', (e) => {
      e.stopPropagation();
      showPhoto(lightboxState.currentIndex - 1);
    });

    lightboxNext?.addEventListener('click', (e) => {
      e.stopPropagation();
      showPhoto(lightboxState.currentIndex + 1);
    });

    lightboxClose?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // Keyboard navigation - only add once
    if (!lightboxState.initialized) {
      lightboxState.initialized = true;
      document.addEventListener('keydown', (e: KeyboardEvent) => {
        const currentLightbox = document.getElementById('lightbox');
        if (!currentLightbox?.classList.contains('is-open')) return;

        const img = document.getElementById('lightbox-img') as HTMLImageElement;
        const photos = Array.from({ length: lightboxState.photoCount }, (_, i) => i + 1);

        if (e.key === 'Escape') {
          currentLightbox.classList.remove('is-open');
          document.body.style.overflow = '';
        }
        if (e.key === 'ArrowLeft') {
          lightboxState.currentIndex = ((lightboxState.currentIndex - 1) % lightboxState.photoCount + lightboxState.photoCount) % lightboxState.photoCount;
          if (img) {
            img.src = `${lightboxState.base}images/photos/${photos[lightboxState.currentIndex]}.jpg`;
          }
        }
        if (e.key === 'ArrowRight') {
          lightboxState.currentIndex = (lightboxState.currentIndex + 1) % lightboxState.photoCount;
          if (img) {
            img.src = `${lightboxState.base}images/photos/${photos[lightboxState.currentIndex]}.jpg`;
          }
        }
      });
    }

    // Mouse drag for carousel
    if (carousel && track) {
      let isDragging = false;
      let startX = 0;
      let scrollLeft = 0;
      let dragDistance = 0;

      carousel.addEventListener('mousedown', (e) => {
        isDragging = true;
        carousel.classList.add('is-dragging');
        startX = e.pageX - carousel.offsetLeft;
        scrollLeft = carousel.scrollLeft;
        dragDistance = 0;
      });

      carousel.addEventListener('mouseleave', () => {
        if (isDragging) {
          isDragging = false;
          carousel.classList.remove('is-dragging');
        }
      });

      carousel.addEventListener('mouseup', () => {
        isDragging = false;
        carousel.classList.remove('is-dragging');

        // Prevent click if we dragged more than 5px
        if (Math.abs(dragDistance) > 5) {
          carousel.classList.add('just-dragged');
          setTimeout(() => carousel.classList.remove('just-dragged'), 100);
        }
      });

      carousel.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        e.preventDefault();
        const x = e.pageX - carousel.offsetLeft;
        const walk = (x - startX) * 2;
        dragDistance = walk;
        carousel.scrollLeft = scrollLeft - walk;
      });

      // Touch support (mobile)
      carousel.addEventListener('touchstart', (e) => {
        isDragging = true;
        carousel.classList.add('is-dragging');
        startX = e.touches[0].pageX - carousel.offsetLeft;
        scrollLeft = carousel.scrollLeft;
        dragDistance = 0;
      }, { passive: true });

      carousel.addEventListener('touchend', () => {
        isDragging = false;
        carousel.classList.remove('is-dragging');
        if (Math.abs(dragDistance) > 5) {
          carousel.classList.add('just-dragged');
          setTimeout(() => carousel.classList.remove('just-dragged'), 100);
        }
      });

      carousel.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const x = e.touches[0].pageX - carousel.offsetLeft;
        const walk = (x - startX) * 2;
        dragDistance = walk;
        carousel.scrollLeft = scrollLeft - walk;
      }, { passive: true });
    }

    // Swipe navigation in lightbox
    if (lightbox) {
      let touchStartX = 0;

      lightbox.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
      }, { passive: true });

      lightbox.addEventListener('touchend', (e) => {
        const touchEndX = e.changedTouches[0].clientX;
        const diff = touchStartX - touchEndX;

        if (Math.abs(diff) > 50) {
          if (diff > 0) {
            showPhoto(lightboxState.currentIndex + 1);
          } else {
            showPhoto(lightboxState.currentIndex - 1);
          }
        }
      });
    }
  }

  // Initialize on page load and after View Transitions
  initPhotoCarousel();
  document.addEventListener('astro:page-load', initPhotoCarousel);
</script>
