---
import { type Lang, t, languages } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const base = import.meta.env.BASE_URL;
const homeUrl = lang === 'en' ? '/' : `/${lang}/`;
---

<nav class="wrap header" data-base={base} transition:persist transition:name="header">
  <a href={homeUrl} class="logo">p.v.</a>
  <button class="nav-toggle" aria-label="Toggle navigation menu" id="nav-toggle">
    <span></span>
  </button>
  <div id="nav-links" class="nav-links">
    <a href="#photos" class="navlink">{t(lang, 'nav.photos')}</a>
    <a href="#reel" class="navlink">{t(lang, 'nav.reel')}</a>
    <a href="#work" class="navlink">{t(lang, 'nav.work')}</a>
    <a href="#about" class="navlink">{t(lang, 'nav.about')}</a>
    <a href="#services" class="navlink">{t(lang, 'nav.services')}</a>
    <a href="https://instagram.com/nickygreys" target="_blank" rel="noopener" class="navlink instagram">@nickygreys</a>
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
      <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="12" cy="12" r="5"/>
        <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
      </svg>
      <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
    <div class="lang-toggle" id="lang-toggle">
      {Object.keys(languages).map((l) => (
        <button
          class:list={['lang-btn', { 'is-active': l === lang }]}
          data-lang={l}
        >
          {l.toUpperCase()}
        </button>
      ))}
    </div>
  </div>
</nav>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    z-index: 100;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    padding-top: 22px;
    padding-bottom: 22px;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.4s ease, border-color 0.4s ease;
  }

  /* Transparent state - light text over hero */
  .header:not(.is-scrolled) {
    color: rgba(255, 255, 255, 0.9);
  }

  .header:not(.is-scrolled) .logo {
    color: rgba(255, 255, 255, 0.95);
  }

  .header:not(.is-scrolled) .navlink {
    color: rgba(255, 255, 255, 0.8);
  }

  .header:not(.is-scrolled) .navlink:hover {
    color: rgba(255, 255, 255, 1);
  }

  .header:not(.is-scrolled) .instagram {
    color: rgba(255, 255, 255, 0.9);
  }

  .header:not(.is-scrolled) .theme-toggle {
    color: rgba(255, 255, 255, 0.8);
  }

  .header:not(.is-scrolled) .lang-btn {
    color: rgba(255, 255, 255, 0.6);
  }

  .header:not(.is-scrolled) .lang-btn.is-active {
    color: rgba(255, 255, 255, 0.95);
  }

  /* Scrolled state - back to normal colors but still transparent */
  .header.is-scrolled {
    /* Keep transparent, just restore normal text colors */
  }

  .header.is-scrolled .logo {
    color: var(--color-text);
  }

  .header.is-scrolled .navlink {
    color: var(--color-text);
  }

  .header.is-scrolled .navlink:hover {
    color: var(--color-accent-700);
  }

  .header.is-scrolled .instagram {
    color: var(--color-accent-700);
  }

  .header.is-scrolled .theme-toggle {
    color: var(--color-text);
  }

  .header.is-scrolled .lang-btn {
    color: color-mix(in srgb, var(--color-text) 50%, transparent);
  }

  .header.is-scrolled .lang-btn.is-active {
    color: var(--color-text);
  }

  .nav-links {
    display: flex;
    gap: 30px;
    align-items: baseline;
    font-family: var(--font-body);
    font-size: 14px;
  }

  .navlink {
    transition: color 0.3s ease;
  }

  .instagram {
    color: var(--color-accent-700);
    transition: color 0.3s ease;
  }

  /* Theme Toggle */
  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    opacity: 0.7;
    transition: opacity 0.3s ease, transform 0.3s ease, color 0.3s ease;
  }

  .theme-toggle:hover {
    opacity: 1;
    transform: scale(1.1);
  }

  .theme-toggle:active {
    transform: scale(0.95) rotate(15deg);
  }

  .theme-toggle .icon-sun,
  .theme-toggle .icon-moon {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  /* Light mode: show sun, hide moon */
  .theme-toggle .icon-sun {
    display: block;
  }
  .theme-toggle .icon-moon {
    display: none;
  }

  /* Dark mode: show moon, hide sun */
  :global([data-theme="dark"]) .theme-toggle .icon-sun {
    display: none;
  }
  :global([data-theme="dark"]) .theme-toggle .icon-moon {
    display: block;
  }

  /* Mobile header adjustments */
  @media (max-width: 900px) {
    .header {
      align-items: center;
      padding-top: 16px;
      padding-bottom: 16px;
    }

    .theme-toggle {
      padding: 10px;
      margin-right: 8px;
    }
  }
</style>

<script>
  // Track if listeners are already set up (prevents duplicates after View Transitions)
  let headerInitialized = false;

  function initHeader() {
    const navToggle = document.getElementById('nav-toggle');
    const navLinks = document.getElementById('nav-links');
    const header = document.querySelector('.header');
    const themeToggle = document.getElementById('theme-toggle');
    const langToggle = document.getElementById('lang-toggle');
    const basePath = (header as HTMLElement)?.dataset.base || '/';

    function closeMobileMenu() {
      navToggle?.classList.remove('is-open');
      navLinks?.classList.remove('is-open');
    }

    function updateHeaderState() {
      if (!header) return;
      const scrolled = window.scrollY > 80;
      header.classList.toggle('is-scrolled', scrolled);
    }

    function getThemePreference(): 'light' | 'dark' {
      const stored = localStorage.getItem('theme');
      if (stored === 'dark' || stored === 'light') return stored;
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    function setTheme(theme: 'light' | 'dark') {
      document.documentElement.classList.add('theme-transitioning');
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);

      const metaTheme = document.querySelector('meta[name="theme-color"]');
      if (metaTheme) {
        metaTheme.setAttribute('content', theme === 'dark' ? '#141210' : '#f3f2f2');
      }

      setTimeout(() => {
        document.documentElement.classList.remove('theme-transitioning');
      }, 400);
    }

    // Initialize states
    updateHeaderState();
    const currentTheme = getThemePreference();
    if (currentTheme === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
    }

    // Only add event listeners once
    if (!headerInitialized) {
      headerInitialized = true;

      // Scroll detection
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            updateHeaderState();
            ticking = false;
          });
          ticking = true;
        }
      });

      // Mobile menu toggle
      navToggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        navToggle.classList.toggle('is-open');
        navLinks?.classList.toggle('is-open');
      });

      // Close menu when clicking a nav link
      navLinks?.querySelectorAll('.navlink').forEach(link => {
        link.addEventListener('click', closeMobileMenu);
      });

      // Close menu when clicking outside
      document.addEventListener('click', (e) => {
        const currentHeader = document.querySelector('.header');
        const currentNavLinks = document.getElementById('nav-links');
        if (!currentHeader?.contains(e.target as Node) && currentNavLinks?.classList.contains('is-open')) {
          closeMobileMenu();
        }
      });

      // Close menu on escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          closeMobileMenu();
        }
      });

      // Close menu on resize to desktop
      window.addEventListener('resize', () => {
        if (window.innerWidth > 900) {
          closeMobileMenu();
        }
      });

      // Theme toggle
      themeToggle?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        setTheme(current === 'dark' ? 'light' : 'dark');
      });

      // System theme changes
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
        if (!localStorage.getItem('theme')) {
          setTheme(e.matches ? 'dark' : 'light');
        }
      });

      // Language toggle
      langToggle?.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.classList.contains('lang-btn')) {
          const newLang = target.dataset.lang;
          if (newLang) {
            localStorage.setItem('lang', newLang);
            window.location.href = newLang === 'en' ? basePath : `${basePath}${newLang}/`;
          }
        }
      });
    }
  }

  // Initialize on load and after View Transitions
  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>
