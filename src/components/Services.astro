---
import { type Lang, t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const services = [
  {
    number: '01',
    titleKey: 'services.cinematography' as const,
    descKey: 'services.cinematography.desc' as const,
  },
  {
    number: '02',
    titleKey: 'services.photography' as const,
    descKey: 'services.photography.desc' as const,
  },
  {
    number: '03',
    titleKey: 'services.editing' as const,
    descKey: 'services.editing.desc' as const,
  },
];
---

<section id="services" class="section-reveal services-section">
  <div class="wrap services-inner">
    <span class="kick reveal">{t(lang, 'services.label')}</span>
    <div class="svc-grid">
      {services.map((service, index) => (
        <div class={`service-card reveal delay-${index + 1}`}>
          <div class="service-number">{service.number}</div>
          <div class="service-divider"></div>
          <h3>{t(lang, service.titleKey)}</h3>
          <p class="prose service-desc">{t(lang, service.descKey)}</p>
        </div>
      ))}
    </div>

    <div class="book-cta reveal delay-4">
      <a
        href="https://calendly.com/ussseryizis/book-a-consultation"
        target="_blank"
        rel="noopener"
        class="btn btn-primary book-btn"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        {t(lang, 'services.book')}
      </a>
      <span class="book-hint">{t(lang, 'services.book.desc')}</span>
    </div>
  </div>
</section>

<style>
  .services-section {
    background: var(--color-neutral-100);
    border-top: 1px solid var(--color-divider);
    border-bottom: 1px solid var(--color-divider);
  }

  .services-inner {
    padding-top: clamp(56px, 7vw, 88px);
    padding-bottom: clamp(56px, 7vw, 88px);
  }

  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(32px, 4vw, 48px);
    margin-top: 30px;
  }

  .service-number {
    font-family: var(--font-heading);
    font-size: 20px;
    color: var(--color-accent-700);
  }

  .service-divider {
    height: 1px;
    background: var(--color-divider);
    margin: 14px 0;
  }

  .service-card h3 {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: 26px;
    margin: 0;
  }

  .service-desc {
    font-size: 15px;
    text-align: justify;
    hyphens: auto;
    margin: 14px 0 0;
  }

  .book-cta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: clamp(40px, 5vw, 56px);
    padding-top: clamp(32px, 4vw, 48px);
    border-top: 1px solid var(--color-divider);
  }

  .book-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .book-btn svg {
    flex-shrink: 0;
  }

  .book-hint {
    font-family: var(--font-body);
    font-size: 14px;
    color: color-mix(in srgb, var(--color-text) 55%, transparent);
  }

  /* Mobile styles */
  @media (max-width: 900px) {
    .services-inner {
      padding-top: 48px;
      padding-bottom: 48px;
    }

    .svc-grid {
      grid-template-columns: 1fr;
      gap: 32px;
      margin-top: 24px;
    }

    .service-card {
      padding: 24px;
      background: var(--color-bg);
      border-radius: var(--radius-md);
      border: 1px solid var(--color-divider);
    }
  }

  @media (max-width: 600px) {
    .services-inner {
      padding-top: 40px;
      padding-bottom: 40px;
    }

    .service-card h3 {
      font-size: 22px;
    }

    .service-desc {
      font-size: 14px;
      text-align: left;
    }

    .book-cta {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      margin-top: 32px;
      padding-top: 28px;
    }

    .book-btn {
      width: 100%;
      justify-content: center;
    }

    .book-hint {
      text-align: center;
      width: 100%;
    }
  }
</style>
